#!/bin/sh
# Pre-push gate: typecheck + lint the frontend before code leaves the machine.
# This is the fast local cure for "Vite ran fine but the build is type-broken".
# Bypass once (rarely!) with:  git push --no-verify
ROOT="$(git rev-parse --show-toplevel)"
echo "▶ pre-push: frontend typecheck + lint"
cd "$ROOT/frontend" || exit 1

npm run typecheck || { echo "✖ tsc --noEmit failed — push aborted (fix the types, or: git push --no-verify)"; exit 1; }
npm run lint      || { echo "✖ eslint failed — push aborted (fix it, or: git push --no-verify)"; exit 1; }

echo "✓ frontend checks passed"
